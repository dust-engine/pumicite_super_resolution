load("@rules_cc//cc:cc_import.bzl", "cc_import")
load("@rules_cc//cc:cc_library.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "dlss_headers",
    hdrs = glob(["include/*.h"]),
    includes = ["include"],
)

cc_import(
    name = "dlss_windows",
    # nvsdk_ngx_d.lib is a static library (not an import lib) — _d denotes
    # dynamic-CRT linkage which matches Rust's MSVC default. The actual
    # feature implementation lives in nvngx_dlssd.dll, loaded at runtime
    # by NGX from the application directory.
    static_library = "lib/Windows_x86_64/x64/nvsdk_ngx_d.lib",
    target_compatible_with = ["@platforms//os:windows"],
)

cc_import(
    name = "dlss_linux",
    static_library = "lib/Linux_x86_64/libnvsdk_ngx.a",
    target_compatible_with = ["@platforms//os:linux"],
)

cc_library(
    name = "dlss",
    deps = [":dlss_headers"] + select({
        "@platforms//os:windows": [":dlss_windows"],
        "@platforms//os:linux": [":dlss_linux"],
        "//conditions:default": [],
    }),
)

# DLLs that NGX loads at runtime. Per section 4.2 of the DLSS Programming
# Guide, the `rel/` variants ship next to the application binary; the
# `dev/` variants include debug overlays and indicators useful while
# developing but MUST NOT be distributed.
#
# Pass `--config=dlss_dev` (see .bazelrc) to bundle the development DLLs.
#
# We expose only the DLSS-RR (RayReconstruction, "DLSSD") runtime since
# that's the only NGX feature this crate uses. Add `nvngx_dlss.dll` (super
# resolution) or `nvngx_dlssg.dll` (frame generation) here if they're ever
# wired up.
config_setting(
    name = "dev_windows",
    values = {"define": "dlss=dev"},
    constraint_values = ["@platforms//os:windows"],
)

config_setting(
    name = "dev_linux",
    values = {"define": "dlss=dev"},
    constraint_values = ["@platforms//os:linux"],
)

# Copy the selected DLSSD library into a stable `runtime/` subdir so callers
# can reference one fixed path that doesn't change between dev/rel builds. NGX
# requires the original filenames, so we relocate but don't rename.
#
# `genrule.outs` is not configurable, so the dev/rel select goes on `srcs`
# and the platform split is expressed as two separate per-OS genrules.
genrule(
    name = "dlssd_runtime_windows",
    srcs = select({
        ":dev_windows": ["lib/Windows_x86_64/dev/nvngx_dlssd.dll"],
        "//conditions:default": ["lib/Windows_x86_64/rel/nvngx_dlssd.dll"],
    }),
    outs = ["runtime/nvngx_dlssd.dll"],
    cmd = "cp $< $@",
    cmd_bat = 'copy /Y "$<" "$@"',
    target_compatible_with = ["@platforms//os:windows"],
)

genrule(
    name = "dlssd_runtime_linux",
    srcs = select({
        ":dev_linux": ["lib/Linux_x86_64/dev/libnvidia-ngx-dlssd.so.310.6.0"],
        "//conditions:default": ["lib/Linux_x86_64/rel/libnvidia-ngx-dlssd.so.310.6.0"],
    }),
    outs = ["runtime/libnvidia-ngx-dlssd.so.310.6.0"],
    cmd = "cp $< $@",
    target_compatible_with = ["@platforms//os:linux"],
)

filegroup(
    name = "dlssd_runtime",
    srcs = select({
        "@platforms//os:windows": [":dlssd_runtime_windows"],
        "@platforms//os:linux": [":dlssd_runtime_linux"],
        "//conditions:default": [],
    }),
)
